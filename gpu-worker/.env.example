# ── Depth Estimation ───────────────────────────
# Backend: "midas" (CPU-friendly) or "flashdepth" (GPU, requires CUDA)
DEPTH_BACKEND=midas

# MiDaS model type: "MiDaS_small" (fast), "DPT_Hybrid", "DPT_Large" (best quality)
MIDAS_MODEL_TYPE=MiDaS_small

# ── Processing ─────────────────────────────────
# Frames are resized to this resolution before depth estimation
PROCESS_WIDTH=640
PROCESS_HEIGHT=360

# ── Stereo Parameters ─────────────────────────
IPD_MM=65.0           # Inter-pupillary distance (mm)
FOCAL_LENGTH_PX=500.0 # Virtual camera focal length (pixels)
MAX_DISPARITY_PX=30   # Max horizontal pixel shift for stereo

# ── Splat Generation ──────────────────────────
SPLAT_VOXEL_SIZE=0.02     # Voxel grid side length in meters
SPLAT_MAX_COUNT=40000     # Max Gaussians per frame
DELTA_THRESHOLD=0.005     # Position change threshold for delta encoding
BG_FLOW_EXTREME=50.0      # Optical flow magnitude → 2D fallback trigger
KEYFRAME_INTERVAL_S=3.0   # Seconds between forced keyframes

# ── Server ─────────────────────────────────────
HOST=0.0.0.0
PORT=8000
